VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Alternative names supported for Vercel projects that already use NEXT_PUBLIC_* variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Runtime-only names also supported by the Vercel API route.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Optional Vercel server-only key. Do not expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-private-service-role-or-secret-key
SUPABASE_SECRET_KEY=your-private-sb-secret-key
SUPABASE_ARTISTS_TABLE=artists
